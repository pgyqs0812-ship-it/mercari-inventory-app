<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- PyInstaller bundles load .so extensions signed with different identities. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- CPython requires writable+executable memory for its eval loop. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Flask binds a listening socket on port 5050. -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Selenium connects to the local ChromeDriver process. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
